      <column caption='Gender1' datatype='string' name='[Calculation_0357087462735872]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Gender]=1 THEN &quot;Female&quot;&#13;&#10;ELSE &quot;Male&quot;&#13;&#10;END' />
      </column>
      <column caption='Breakfast1' datatype='string' name='[Calculation_0357087463227393]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [breakfast]=1 THEN &quot;Cereals&quot;&#13;&#10;ELSE &quot;Donut&quot;&#13;&#10;END' />
      </column>
      <column caption='Health' datatype='string' name='[Calculation_0357087464632322]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF INT([fruit_day])&gt;=4&#13;&#10;AND INT([fries])&lt;=2&#13;&#10;AND INT([veggies_day])&gt;=4&#13;&#10;AND INT([exercise])&gt;=1&#13;&#10;THEN &quot;Healthy&quot;&#13;&#10;ELSE &quot;Unhealthy&quot;&#13;&#10;END' />
      </column>
      <column caption='Weight1' datatype='integer' name='[Calculation_0357087467421699]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ISNULL([weight]) THEN 160&#13;&#10;ELSE [weight]&#13;&#10;END' />
      </column>
      <column caption='Calculation2' datatype='integer' hidden='true' name='[Calculation_0357087467810820]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ISNULL([weight]) THEN 160&#13;&#10;ELSE [weight]&#13;&#10;END' />
      </column>
      <column caption='Calculation1' datatype='integer' name='[Calculation_1727903782162435]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 1727903780790274]=&quot;veggies_day&quot; THEN [veggies_day]&#13;&#10;ELSEIF [Parameters].[Parameter 1727903780790274]=&quot;vitamins&quot; THEN [vitamins]&#13;&#10;ELSE [fruit_day]&#13;&#10;END' />
      </column>
      <column caption='Calculation3' datatype='integer' name='[Calculation_1727904260591621]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 1727904198553604]=&quot;thai_food&quot; THEN [thai_food]&#13;&#10;ELSEIF [Parameters].[Parameter 1727904198553604]=&quot;italian_food&quot; THEN [italian_food]&#13;&#10;ELSEIF [Parameters].[Parameter 1727904198553604]=&quot;greek_food&quot; THEN [greek_food]&#13;&#10;ELSEIF [Parameters].[Parameter 1727904198553604]=&quot;indian_food&quot; THEN [indian_food]&#13;&#10;ELSE [persian_food]&#13;&#10;END' />
      </column>
      <column caption='Calculation4' datatype='string' name='[Calculation_1727904274210823]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS(LOWER([comfort_food_reasons]), &quot;bored&quot;) THEN &quot;Boredom&quot;&#13;&#10;&#13;&#10;ELSEIF CONTAINS(LOWER([comfort_food_reasons]), &quot;sad&quot;) THEN &quot;Sadness&quot;&#13;&#10;&#13;&#10;ELSEIF CONTAINS(LOWER([comfort_food_reasons]), &quot;stress&quot;) THEN &quot;Stress&quot;&#13;&#10;&#13;&#10;ELSEIF CONTAINS(LOWER([comfort_food_reasons]), &quot;happy&quot;) THEN &quot;Happiness&quot;&#13;&#10;&#13;&#10;ELSE &quot;None&quot;&#13;&#10;&#13;&#10;END' />
      </column>
