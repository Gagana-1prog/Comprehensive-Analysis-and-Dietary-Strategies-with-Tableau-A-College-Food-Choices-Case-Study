    <worksheet name='Health vs greek_food consumption'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1'>Health vs greek_food consumption</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='food_coded (food_coded)' name='federated.13x24da0pt48iz0zom28c1nmrwae' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Parameter 2' datatype='string' name='[Parameter 1727904198553604]' param-domain-type='list' role='measure' type='nominal' value='&quot;thai_food&quot;'>
              <calculation class='tableau' formula='&quot;thai_food&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.13x24da0pt48iz0zom28c1nmrwae'>
            <column caption='Gender1' datatype='string' name='[Calculation_0357087462735872]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Gender]=1 THEN &quot;Female&quot;&#13;&#10;ELSE &quot;Male&quot;&#13;&#10;END' />
            </column>
            <column caption='Health' datatype='string' name='[Calculation_0357087464632322]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF INT([fruit_day])&gt;=4&#13;&#10;AND INT([fries])&lt;=2&#13;&#10;AND INT([veggies_day])&gt;=4&#13;&#10;AND INT([exercise])&gt;=1&#13;&#10;THEN &quot;Healthy&quot;&#13;&#10;ELSE &quot;Unhealthy&quot;&#13;&#10;END' />
            </column>
            <column caption='Calculation3' datatype='integer' name='[Calculation_1727904260591621]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1727904198553604]=&quot;thai_food&quot; THEN [thai_food]&#13;&#10;ELSEIF [Parameters].[Parameter 1727904198553604]=&quot;italian_food&quot; THEN [italian_food]&#13;&#10;ELSEIF [Parameters].[Parameter 1727904198553604]=&quot;greek_food&quot; THEN [greek_food]&#13;&#10;ELSEIF [Parameters].[Parameter 1727904198553604]=&quot;indian_food&quot; THEN [indian_food]&#13;&#10;ELSE [persian_food]&#13;&#10;END' />
            </column>
            <column datatype='integer' hidden='true' name='[Gender]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_0357087462735872]' derivation='Count' name='[cnt:Calculation_0357087462735872:qk]' pivot='key' type='quantitative' />
            <column caption='Exercise' datatype='string' name='[exercise]' role='dimension' type='nominal' />
            <column caption='Fries' datatype='integer' name='[fries]' role='measure' type='quantitative' />
            <column caption='Fruit Day' datatype='integer' name='[fruit_day]' role='dimension' type='quantitative' />
            <column caption='Greek Food' datatype='integer' name='[greek_food]' role='measure' type='quantitative' />
            <column caption='Indian Food' datatype='integer' name='[indian_food]' role='measure' type='quantitative' />
            <column caption='Italian Food' datatype='integer' name='[italian_food]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_0357087464632322]' derivation='None' name='[none:Calculation_0357087464632322:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1727904260591621]' derivation='None' name='[none:Calculation_1727904260591621:qk]' pivot='key' type='quantitative' />
